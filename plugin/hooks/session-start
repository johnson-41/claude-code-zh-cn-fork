#!/usr/bin/env bash
# session-start hook for claude-code-zh-cn
# 1. 注入中文上下文指令
# 2. 检测插件 Release 更新并同步安装态
# 3. 检测 cli.js 版本变更，自动重 patch


# 确保 UTF-8 locale（Cloud 环境默认可能为 C/POSIX，中文输出会乱码）
export LC_ALL="${LC_ALL:-C.UTF-8}"
export LANG="${LANG:-en_US.UTF-8}"

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$HOME/.claude/plugins/claude-code-zh-cn}"
MARKER_FILE="$PLUGIN_ROOT/.patched-version"
SOURCE_REPO_FILE="$PLUGIN_ROOT/.source-repo"
LAST_UPDATE_CHECK_FILE="$PLUGIN_ROOT/.last-update-check"
UPDATE_CHECK_INTERVAL_SECONDS="${ZH_CN_UPDATE_CHECK_INTERVAL_SECONDS:-21600}"
LAUNCHER_BIN_DIR="${ZH_CN_LAUNCHER_BIN_DIR:-$HOME/.claude/bin}"

source "$PLUGIN_ROOT/compute-patch-revision.sh"
source "$PLUGIN_ROOT/lib/common.sh"
source "$PLUGIN_ROOT/hooks/auto-update.sh"
source "$PLUGIN_ROOT/hooks/auto-repatch.sh"

# 自动更新
check_and_update

# 自动 patch 检测
check_and_repatch

# 读取用户输入
read -r INPUT

# 输出中文上下文注入
cat <<HOOK_OUTPUT
{
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "## 中文本地化提示\n\n你正在使用中文本地化版本。请遵循以下规则：\n- 默认使用中文（简体）回复用户\n- 技术术语保留英文（如 API、PR、git、npm、React、TypeScript 等）\n- 使用中文标点符号（，。！？：；「」）\n- 错误信息尽量提供中文解释，附带英文原文\n- 保持简洁直接的风格\n- 代码注释使用中文\n- 日期格式使用 YYYY年MM月DD日\n\n## 常见错误信息翻译参考\n- Permission denied → 权限被拒绝\n- File not found → 文件未找到\n- Command not found → 命令未找到\n- Connection refused → 连接被拒绝\n- Timeout → 超时\n- Rate limited → 请求频率受限\n- Internal server error → 服务器内部错误\n- Unauthorized → 未授权\n- Forbidden → 禁止访问\n- Not found → 未找到${AUTO_UPDATE_MSG:+\\n\\n## 自动更新\\n${AUTO_UPDATE_MSG}}${AUTO_PATCH_MSG:+\\n\\n## 自动修复\\n${AUTO_PATCH_MSG}}"
  }
}
HOOK_OUTPUT
