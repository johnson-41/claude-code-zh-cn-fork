#!/usr/bin/env bash
# notification hook for claude-code-zh-cn
# Translates common notifications to Chinese (bash 3.x compatible)

read -r INPUT

# Extract notification message and translate via node for safe JSON output
ZH_CN_NOTIFICATION_INPUT="$INPUT" node -e "
try {
  const data = JSON.parse(process.env.ZH_CN_NOTIFICATION_INPUT || '{}');
  const msg = String(data.message || '');
  const map = {
    'Rate limited': '请求频率受限，请稍后再试',
    'Token limit reached': 'Token 用量已达上限',
    'Session expired': '会话已过期',
    'Context window': '上下文窗口即将用尽，建议使用 /compact 压缩',
    'Usage limit': '使用额度已达上限',
    'Auto-compact': '正在自动压缩对话历史...',
  };
  let translated = '';
  for (const [key, val] of Object.entries(map)) {
    if (msg.includes(key)) { translated = val; break; }
  }
  if (translated) {
    process.stdout.write(JSON.stringify({
      hookSpecificOutput: {
        hookEventName: 'Notification',
        additionalContext: '通知翻译：' + translated,
      },
    }));
  } else {
    process.stdout.write('{}');
  }
} catch { process.stdout.write('{}'); }
" 2>/dev/null
